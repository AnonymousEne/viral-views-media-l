{
  "name": "viral-views",
  "version": "1.0.0-beta.1",
  "private": false,
  "description": "Viral Views - Media Social Streaming Platform for Video Sharing, Editing, Rap Battles, Cyphers, and Creator Battles",
  "scripts": {
    "dev": "next dev -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "export": "next build && next export",
    "deploy": "npm run build && firebase deploy",
    "deploy:production": "./scripts/deploy-production.sh",
    "deploy:staging": "npm run build && firebase deploy --only hosting",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "setup": "npm install && npm run setup:python",
    "setup:python": "pip install -r requirements.txt",
    "beta:deploy": "npm run build && firebase deploy --only hosting",
    "beta:preview": "firebase hosting:channel:deploy beta"
  },
